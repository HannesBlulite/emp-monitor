# ═══════════════════════════════════════════════════════════════════════════
# EMP Monitor Agent - Environment Configuration (TEMPLATE)
# ═══════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your values.
# See .env for the live production configuration.
#
# ═══════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────
SERVER_URL=https://your-server.example.com

# ── Network share paths (comma-separated, tried in order) ────────────────
SHARE_PATHS=\\SERVERNAME\ShareName,\\10.0.0.1\ShareName

# ── Agent install directory (on the mapped E: drive) ─────────────────────
AGENT_DIR=E:\DDC\tools\agent

# ── Scheduled task name ───────────────────────────────────────────────────
TASK_NAME=EmpMonitorAgent

# ── Minimum Python version required ──────────────────────────────────────
PYTHON_MIN_VERSION=3.10

# ── Default agent settings ───────────────────────────────────────────────
SCREENSHOT_INTERVAL=300
ACTIVITY_REPORT_INTERVAL=60
SCREENSHOT_QUALITY=60
SCREENSHOT_FORMAT=JPEG
IDLE_THRESHOLD=120
LOG_LEVEL=INFO

# ── Employee tokens ──────────────────────────────────────────────────────
# Format: TOKEN_<lowercase_name>=<64-character hex token from Django admin>
# TOKEN_firstname=abc123def456...
