[Unit]
Description=EMP Monitor Gunicorn Service
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/emp-monitor/server
EnvironmentFile=/opt/emp-monitor/.env
ExecStart=/opt/emp-monitor/venv/bin/gunicorn --workers 3 --bind 127.0.0.1:8001 empmonitor_server.wsgi:application
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
